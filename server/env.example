# Copy to .env and fill in your Supabase credentials.
# Get these from: Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=drops

PORT=3001

# AI synthesis and digest: use either OpenAI or Gemini (or both; Gemini is preferred for synthesis when set)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
SYNTHESIZE_SECRET=your-secret-for-cron
